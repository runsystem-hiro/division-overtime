# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.eggs/
build/
dist/

# Python test / lint / type-check / coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml

# =============================================================================
# Python virtual environments
# =============================================================================
.venv/
venv/
env/
ENV/

# =============================================================================
# Environment variables / secrets
# =============================================================================
.env
.env.*
!.env.example

# Production-only configuration
config/production.toml

# =============================================================================
# Runtime data
# =============================================================================
logs/
tmp/
var/
*.log
*.pid
*.lock

# Employee data and generated operational data
data/employeeKey.csv
data/*.json
data/*.jsonl

# Runtime backups may contain employee data or other secrets
/data/backups/

# =============================================================================
# SQLite
# =============================================================================
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal

# =============================================================================
# Frontend / Node.js / Vite
# =============================================================================
node_modules/
frontend/node_modules/
frontend/dist/
frontend/coverage/

*.tsbuildinfo
frontend/vite.config.js
frontend/vite.config.d.ts

# Node / npm logs and caches
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.pnpm-store/

# =============================================================================
# Generated / captured media
# =============================================================================
*.jpg
*.jpeg
*.png

# Allow repository-managed documentation images when introduced
!docs/images/
!docs/images/**/*.jpg
!docs/images/**/*.jpeg
!docs/images/**/*.png

# =============================================================================
# Backup / archive files
# =============================================================================
*.zip
*.tar
*.tar.gz
*.tgz
*.bak
*.backup

# =============================================================================
# Raspberry Pi / deployment overrides
# =============================================================================
*.service.local
*.timer.local

# =============================================================================
# Editor / IDE
# =============================================================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# =============================================================================
# OS-generated files
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Internal reference files
# =============================================================================
docs/reference/*
!docs/reference/.gitkeep

# =============================================================================
# Legacy / retired sources
# =============================================================================
legacy/
.old/

# Local development generated data
/data/development/
/var/development/
